{
  "name": "@rescript-react-native/flash-list",
  "description": "ReScript bindings for @shopify/flash-list",
  "version": "2.1.0",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@rescript/react": ">=0.14.1",
    "rescript-react-native": ">=0.82.1",
    "@shopify/flash-list": ">=2.0.0"
  },
  "overrides": {
    "react": "^19.1.0"
  },
  "repository": "https://github.com/rescript-react-native/flash-list.git",
  "license": "MIT",
  "keywords": [
    "rescript",
    "react-native",
    "flash-list"
  ],
  "files": [
    "*.md",
    "rescript.json",
    "src/**/*.res",
    "src/**/*.resi",
    "src/**/*.js",
    "!src/**/*.bs.js"
  ],
  "scripts": {
    "prepare": "husky install",
    "format:most": "prettier --write \"**/*.{md,json,js,css}\"",
    "format:res": "rescript format -all",
    "format": "npm run format:most && npm run format:res",
    "re:start": "rescript build -w",
    "re:build": "rescript",
    "re:clean-build": "rescript clean && rescript",
    "start": "npm run re:start",
    "build": "npm run re:build",
    "test": "npm run re:clean-build",
    "release": "npmpub"
  },
  "devDependencies": {
    "rescript": "^11.1.0",
    "@rescript/react": "^0.14.1",
    "rescript-react-native": ">=0.82.1",
    "@shopify/flash-list": "^2.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^13.0.0",
    "npmpub": "^5.0.0",
    "prettier": "^2.0.0"
  },
  "prettier": {
    "trailingComma": "all"
  },
  "lint-staged": {
    "*.{md,json,js,css}": "prettier --write",
    "*.{res,resi}": "rescript format"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}